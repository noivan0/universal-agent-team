# Cycle Time Monitoring System - Environment Configuration Template
# Copy this file to .env and fill in with your actual values
# NEVER commit the .env file to version control!
#
# SECURITY WARNING (Phase 1 Critical Fixes - CRITICAL ISSUE #2):
# - ALL credentials MUST come from environment variables, never hardcoded
# - Use STRONG passwords (minimum 12 characters, mixed case, numbers, symbols)
# - NEVER use default/weak passwords like "password", "postgres", "admin", "123456"
# - For production, use secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
# - All values are validated on startup - weak passwords will cause startup failure
#
# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string with STRONG PASSWORD
# Format: postgresql://username:strongpassword@host:port/database
#
# Development Example:
#   DATABASE_URL=postgresql://postgres:DevPassword123!@localhost:5432/cycle_monitor
#
# Production Example (use managed DB service):
#   DATABASE_URL=postgresql://app_user:ProdSecurePass456#@db.example.com:5432/cycle_monitor
#
# NEVER USE THESE (will be rejected on startup):
#   postgresql://postgres:postgres@...    ❌ Default password
#   postgresql://postgres:password@...    ❌ Weak password
#   postgresql://localhost:...            ❌ Localhost in production
#
DATABASE_URL=

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis connection string for caching and real-time data
# For production, use managed Redis service with authentication
#
# Development:
#   REDIS_URL=redis://localhost:6379
#
# Production (with password):
#   REDIS_URL=redis://:RedisPassword123@redis.example.com:6379/0
#
REDIS_URL=redis://localhost:6379

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Backend API host (used by frontend)
# Must be HTTPS in production
API_HOST=http://localhost:8000

# Frontend URL (used for CORS configuration)
# Must be HTTPS in production
FRONTEND_URL=http://localhost:3000

# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================
# SMTP server for sending alert emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# SMTP credentials - use app-specific passwords, not account password
# For Gmail: Use App Passwords (https://support.google.com/accounts/answer/185833)
# For other providers: Use dedicated email account or app-specific credentials
# NEVER use your main account password!
SMTP_USER=

# SMTP Password - STRONG PASSWORD from environment, never hardcoded
# Will be rejected if empty or too weak
SMTP_PASSWORD=

# Email address for notifications
NOTIFICATION_EMAIL_FROM=noreply@cyclemonitor.com

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG only in development
LOG_LEVEL=INFO

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Maximum retry attempts for failed operations (1-10)
MAX_AGENT_RETRIES=3

# Timeout for long-running operations (seconds, 30-3600)
AGENT_TIMEOUT=300

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
# Set to true only during development
# In production, must be false
DEBUG=false

# ============================================================================
# QUICK WIN 1: UNBOUNDED CACHE GROWTH (Critical Issue #1)
# ============================================================================
# Maximum size for execution order cache (LRU eviction)
# Default: 100 entries (safe for most deployments)
# Increase if you have many unique agent combinations
# CACHE_MAX_SIZE=100

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update all CHANGE_ME values with your actual credentials
#
# 3. For development (local machine):
#    - Keep defaults for DATABASE_URL (localhost PostgreSQL)
#    - Keep defaults for REDIS_URL (localhost Redis)
#    - Use test credentials for SMTP_USER/SMTP_PASSWORD
#
# 4. For production:
#    - Use managed database services (AWS RDS, Heroku Postgres, etc.)
#    - Use managed Redis (AWS ElastiCache, Heroku Redis, etc.)
#    - Use HTTPS URLs (https://...)
#    - Use strong passwords (minimum 16 characters recommended)
#    - Use environment-specific secrets manager
#    - Set DEBUG=false
#    - Use structured logging
#
# 5. Validate configuration:
#    The application will validate all credentials on startup.
#    If validation fails:
#    - Check .env file exists and is readable
#    - Verify all CHANGE_ME placeholders are replaced
#    - Verify passwords are strong enough
#    - Check database/Redis services are running
#
# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
#
# Before deploying to production:
# [ ] All credentials from environment variables (not hardcoded)
# [ ] DATABASE_URL uses strong password (16+ chars, mixed case, numbers, symbols)
# [ ] REDIS_URL includes password authentication
# [ ] SMTP_PASSWORD is app-specific, not main account password
# [ ] DEBUG=false in production
# [ ] API_HOST and FRONTEND_URL are HTTPS
# [ ] Configuration validated successfully on startup
# [ ] Secrets stored in secure secrets manager (not in version control)
# [ ] .env file is in .gitignore (never committed)
# [ ] Database connection is encrypted (TLS/SSL)
#
